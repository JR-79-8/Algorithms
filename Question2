def linearSearch(arr, targetVal):
    count=0
    for i in range(len(arr)):
        if arr[i] == targetVal:
            count+=1
    return count

mylist = [1, 3, 5, 7, 9, 5, 5]
x = 5
result = linearSearch(mylist, x)

if result != -1:
    print("found", result, "times")
else:
    print("not found")
