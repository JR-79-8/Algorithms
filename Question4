def linearSearch(arr, targetVal):
    indexs = []
    for i in range(len(arr)):
        if arr[i] == targetVal:
            indexs.append(i)
    return indexs

mylist = [1, 3, 5, 7, 5, 9, 5, 5]
x = 5
result = linearSearch(mylist, x)

if result != -1:
    print("found at indices", result)
else:
    print("not found")
